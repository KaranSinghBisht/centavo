# Chain: celo (mainnet, 42220) or celoSepolia (testnet, 11142220)
CHAIN=celo
# Optional RPC override; defaults to the public Forno endpoint for the chain
CELO_RPC_URL=
# Dedicated agent wallet — generate with `npm run wallet`. NEVER use a personal key.
AGENT_PRIVATE_KEY=
# LLM reasoner (OpenAI-compatible endpoint; Venice by default)
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=zai-org-glm-4.7
# Server
PORT=8787
# Public host serving the ERC-8004 agent card (no scheme), e.g. centavo.example.com
AGENT_DOMAIN=localhost:8787
# Runtime state directory (orders, audit log, spend ledger)
DATA_DIR=data
# Demo household recipient for the allowance standing order (+ its key, used
# only to send ERC-8004 reputation feedback as the client counterparty)
FAMILY_WALLET=
FAMILY_WALLET_KEY=
# x402 via thirdweb (free key at thirdweb.com/dashboard; create a server wallet
# in the same project). Optional — without it paid endpoints serve in free mode.
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET=
# Price charged per FX quote on our x402 endpoint
X402_QUOTE_PRICE=$0.005
# Public https base URL once the server is deployed (used in the agent card)
PUBLIC_BASE_URL=
